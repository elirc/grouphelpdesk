generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(uuid())
  name            String
  email           String        @unique
  passwordHash    String        @default("")
  role            String
  teamId          String?
  team            Team?         @relation(fields: [teamId], references: [id])
  createdTickets  Ticket[]      @relation("TicketCreator")
  assignedTickets Ticket[]      @relation("TicketAssignee")
  comments        Comment[]
  articles        Article[]
  activityLogs    ActivityLog[]
  statusChanges   TicketStatusHistory[] @relation("StatusChangedBy")
  assignmentChanges TicketAssignmentHistory[] @relation("AssignmentChangedBy")
  assignedInHistory TicketAssignmentHistory[] @relation("AssignedUserHistory")

  @@index([role])
  @@index([teamId])
}

model Ticket {
  id          String        @id @default(uuid())
  title       String
  description String
  status      String        @default("OPEN")
  priority    String
  createdBy   String
  assigneeId  String?
  teamId      String?
  team        Team?         @relation(fields: [teamId], references: [id])
  tags        String        @default("[]")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  resolvedAt  DateTime?
  closedAt    DateTime?
  creator     User          @relation("TicketCreator", fields: [createdBy], references: [id])
  assignee    User?         @relation("TicketAssignee", fields: [assigneeId], references: [id])
  comments    Comment[]
  activity    ActivityLog[]
  statusHistory TicketStatusHistory[]
  assignmentHistory TicketAssignmentHistory[]

  @@index([status])
  @@index([priority])
  @@index([assigneeId])
  @@index([createdBy])
  @@index([teamId])
  @@index([createdAt])
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  teams     Team[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Team {
  id             String       @id @default(uuid())
  name           String
  slug           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          User[]
  tickets        Ticket[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model TicketStatusHistory {
  id         String   @id @default(uuid())
  ticketId   String
  changedBy  String
  fromStatus String?
  toStatus   String
  createdAt  DateTime @default(now())
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor      User     @relation("StatusChangedBy", fields: [changedBy], references: [id])

  @@index([ticketId])
  @@index([changedBy])
  @@index([createdAt])
}

model TicketAssignmentHistory {
  id             String   @id @default(uuid())
  ticketId       String
  changedBy      String
  fromAssigneeId String?
  toAssigneeId   String?
  createdAt      DateTime @default(now())
  ticket         Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor          User     @relation("AssignmentChangedBy", fields: [changedBy], references: [id])
  assignee       User?    @relation("AssignedUserHistory", fields: [toAssigneeId], references: [id])

  @@index([ticketId])
  @@index([changedBy])
  @@index([toAssigneeId])
  @@index([createdAt])
}

model Comment {
  id         String   @id @default(uuid())
  ticketId   String
  authorId   String
  body       String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author     User     @relation(fields: [authorId], references: [id])

  @@index([ticketId])
  @@index([authorId])
  @@index([createdAt])
}

model Article {
  id        String   @id @default(uuid())
  title     String
  body      String
  category  String
  tags      String   @default("[]")
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id])

  @@index([category])
  @@index([authorId])
  @@index([createdAt])
}

model ActivityLog {
  id        String         @id @default(uuid())
  ticketId  String
  userId    String
  action    String
  details   String
  createdAt DateTime       @default(now())
  ticket    Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
