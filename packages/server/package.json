{
  "name": "@helpdesk/server",
  "private": true,
  "authorPersona": "Alex Chen",
  "issue": "#1",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run --root ../.. tests",
    "typecheck": "node -e \"const fs=require('fs');const hasTs=fs.readdirSync('src',{recursive:true}).some((f)=>/\\.ts$/.test(String(f)));process.exit(hasTs?1:0)\" || tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@helpdesk/shared": "*",
    "@prisma/client": "^5.20.0",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.20.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
